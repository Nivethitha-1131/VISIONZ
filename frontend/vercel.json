{
  "version": 2,
  "routes": [
    { "src": "/login$", "dest": "/login.html" },
    { "src": "/landing$", "dest": "/landing.html" },
    { "src": "/profile$", "dest": "/profile.html" },
    { "src": "/analytics$", "dest": "/analytics.html" },
